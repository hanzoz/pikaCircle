{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    [
      "@vectorize-io/opencode-hindsight",
      {
        "hindsightApiUrl": "http://localhost:8888",
        "bankId": "PikaCircle",
        "autoRecall": true,
        "autoRetain": true,
        "recallBudget": "mid",
        "retainEveryNTurns": 3,
        "debug": false
      }
    ]
  ],
  "mcp": {
    "hindsight": {
      "type": "remote",
      "url": "http://localhost:8888/mcp/PikaCircle/",
      "enabled": true
    }
  }
}
